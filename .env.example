# ===== GCP =====
GCP_PROJECT_ID=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS는 gcloud ADC로 대체
# 아래 명령어로 로컬 인증: gcloud auth application-default login

# ===== Gemini API =====
GEMINI_API_KEY=your-api-key

# ===== OAuth 2.0 =====
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-your-secret
OAUTH_REDIRECT_URL=http://localhost:18080/auth/callback

# ===== Cloud Services =====
STORAGE_BUCKET=missless-assets
FIRESTORE_DB=(default)

# ===== Server =====
PORT=18080
DOMAIN=localhost
ENVIRONMENT=development

# ===== Session =====
SESSION_SECRET=your-random-secret-32chars-minimum
